# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
*.swp
*~
.idea/

# VS Code — ignorar solo configuración de usuario, no la de proyecto
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-workspace

# Claude Code — capturas de bugs internas, no van al repo
.claude/bugs/

# Logs y temporales
*.log
*.tmp
*.bak

# Unity .meta (se generan automáticamente al importar en Unity)
*.meta

# Tiles de mapa — son pesados y se distribuyen aparte
# Ignorar contenido pero no el directorio (así funciona la negación)
assets/tiles/**
!assets/tiles/tiles.config.example.js
